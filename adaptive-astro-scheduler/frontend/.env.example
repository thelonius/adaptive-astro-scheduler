# Environment Configuration Template

# This file provides a template for environment configuration variables required for the project.

# API Base URL
VITE_API_BASE_URL=https://your-api-url.com

# Refresh Interval (in milliseconds)
VITE_REFRESH_INTERVAL=300000

# Default Latitude
VITE_DEFAULT_LATITUDE=0

# Default Longitude
VITE_DEFAULT_LONGITUDE=0

# Timezone
VITE_TIMEZONE=UTC

# Other configuration variables can be added as needed.