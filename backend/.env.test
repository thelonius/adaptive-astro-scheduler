# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adaptive_astro
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=5

# Redis
REDIS_URL=redis://localhost:6379

# Ephemeris
EPHEMERIS_MODE=api
EPHEMERIS_API_URL=http://localhost:8000
USE_MOCK_EPHEMERIS=false

# Disable Telegram for testing
TELEGRAM_BOT_TOKEN=
LOG_LEVEL=debug
