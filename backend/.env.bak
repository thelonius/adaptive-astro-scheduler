# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adaptive_astro
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Ephemeris
EPHEMERIS_MODE=api
EPHEMERIS_API_URL=http://localhost:8000
EPHEMERIS_API_KEY=
SWEPH_DATA_PATH=/usr/share/ephe
USE_MOCK_EPHEMERIS=false

# LLM Integration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Cache
CACHE_TTL_EPHEMERIS=31536000
CACHE_TTL_DAY_PAST=31536000
CACHE_TTL_DAY_CURRENT=3600
CACHE_TTL_DAY_FUTURE=86400
CACHE_TTL_NATAL=0

# Queue
BULL_CONCURRENCY=5
BULL_MAX_RETRIES=3

# Telegram Bot
TELEGRAM_BOT_TOKEN=8533167222:AAFhy1o23kD0x702K1FhhxvZCehryGRm7YE
TELEGRAM_WEBHOOK_URL=https://176.123.166.252/webhook/telegram

# Apple HealthKit (future)
HEALTHKIT_ENABLED=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Feature Flags
FEATURE_LLM_RULES=true
FEATURE_REAL_TIME_UPDATES=false
FEATURE_HEALTHKIT_INTEGRATION=false
