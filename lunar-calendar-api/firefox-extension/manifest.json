

{
  "manifest_version": 2,
  "name": "Lunar Calendar Color Palette",
  "version": "1.0.0",
  "description": "Display daily lunar calendar color palettes on new tab pages based on astronomical moon phases",

  "permissions": [
    "activeTab"
  ],

  "background": {
    "scripts": ["background_static.js"],
    "persistent": false
  },

  "chrome_url_overrides": {
    "newtab": "newtab-dist/index.html"
  },

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Lunar Calendar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_security_policy": "script-src 'self' https://cdnjs.cloudflare.com; object-src 'self'"
}