{
  "manifest_version": 2,
  "name": "Lunar Calendar Color Palette",
  "version": "1.0.0",
  "description": "Display daily lunar calendar color palettes on new tab pages based on astronomical moon phases",

  "permissions": [
    "activeTab",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },

  "browser_action": {
    "default_popup": "lang-test.html",
    "default_title": "Lunar Calendar Language Test",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_security_policy": "script-src 'self' https://cdnjs.cloudflare.com; object-src 'self'"
}