{
  "name": "adaptive-astro-scheduler",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev": "./scripts/start-dev.sh",
    "stop": "./scripts/stop-dev.sh",
    "dev:old": "./dev-start.sh && ./QUICK_START.sh",
    "dev:backend": "cd backend && PORT=3001 npm run dev",
    "dev:frontend": "cd frontend && npm run dev", 
    "dev:parallel": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "rm -rf node_modules backend/node_modules frontend/node_modules shared/node_modules",
    "setup": "npm install && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
